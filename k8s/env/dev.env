APP_ENV=dev
K8S_NAMESPACE=front-end-react-dev
K8S_DEPLOYMENT=doe-dev
K8S_SERVICE=doe-dev-svc
INGRESS_HOST=doe-dev.house-software.com.br

API_INTERNAL_BASE_URL=http://venomous-api-dev-svc.back-end-java-dev.svc.cluster.local
NEXT_PUBLIC_API_BASE_URL=/api

REPLICAS=1
MAX_SURGE=0
MAX_UNAVAILABLE=1

CPU_REQUEST=50m
MEMORY_REQUEST=128Mi
CPU_LIMIT=300m
MEMORY_LIMIT=384Mi

HPA_MIN_REPLICAS=1
HPA_MAX_REPLICAS=1
HPA_CPU_AVG_UTILIZATION=80
HPA_MEMORY_AVG_UTILIZATION=85